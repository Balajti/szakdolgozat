# ==== Frontend (local development) ====
# Use "mock" to run the app with local fixtures and demo accounts (no AWS needed).
# Use "amplify" (default) to talk to the real backend described by amplify_outputs.json.
NEXT_PUBLIC_WORDNEST_API_MODE=amplify

# Optional overrides - normally everything comes from amplify_outputs.json,
# which is generated by `npx ampx sandbox` (local) or the Amplify build (hosting).
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=
# NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=
# NEXT_PUBLIC_COGNITO_IDENTITY_POOL_ID=
# NEXT_PUBLIC_APPSYNC_ENDPOINT=
# NEXT_PUBLIC_AWS_REGION=
# NEXT_PUBLIC_STORAGE_BUCKET=

# ==== Server-side (Next.js /api/translate route) ====
# Required for word translation in the story reader when running `npm run dev`.
# In Amplify Hosting set this under App settings -> Environment variables.
GEMINI_API_KEY=

# ==== Backend deploy-time variables (Amplify Hosting -> Environment variables) ====
# FROM_EMAIL: SES-verified sender address for assignment notification emails.
# APP_URL:    the deployed app origin, used for assignment links in emails.
# These are read during `ampx pipeline-deploy` and baked into the
# distribute-assignment Lambda. Without them, emails are skipped (in-app
# notifications still work).
# FROM_EMAIL=
# APP_URL=

# Note: the backend Lambdas' GEMINI_API_KEY is a *secret*, not an env var:
#   local sandbox: npx ampx sandbox secret set GEMINI_API_KEY
#   hosting:       Amplify console -> App settings -> Secrets -> GEMINI_API_KEY
